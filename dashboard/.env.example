# Variables del servidor Node/Vite del dashboard.
# No exponer secretos via Vite define ni import.meta.env del cliente.

APP_URL=http://localhost:3000
ASSISTANT_API_ORIGIN=http://localhost:3001
DASHBOARD_PORT=3001
ASSISTANT_API_PORT=3001
PHP_BIN=php

# OpenRouter: solo server-side
OPENROUTER_API_KEY=__SET_ON_SERVER_ONLY__
OPENROUTER_MODEL=openrouter/free

# Telegram: solo server-side
TELEGRAM_BOT_TOKEN=__SET_ON_SERVER_ONLY__
TELEGRAM_BOT_USERNAME=Falles360Bot
TELEGRAM_CHANNEL_ID=@Falles360
TELEGRAM_WEBHOOK_SECRET=change-me-with-a-long-random-secret
