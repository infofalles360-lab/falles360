# Variables del backend PHP/MySQL.
# Mantener estos valores solo en el servidor. No exponerlos en Vite ni en el cliente.

# Base de datos
FALLES_DB_HOST=127.0.0.1
FALLES_DB_PORT=3306
FALLES_DB_NAME=fallas_app
FALLES_DB_USER=root
FALLES_DB_PASS=

# Sesion
FALLES_SESSION_NAME=falles360_session
FALLES_SESSION_SAMESITE=Lax
FALLES_SESSION_TTL_DAYS=30
# Guarda las sesiones fuera del webroot siempre que sea posible.
FALLES_SESSION_SAVE_PATH=C:/xampp/runtime/falles360/sessions

# URL publica de la app para links absolutos y webhooks
APP_URL=https://example.com/fallasgo/falles360

# Telegram: solo backend
TELEGRAM_BOT_TOKEN=__SET_ON_SERVER_ONLY__
TELEGRAM_BOT_USERNAME=Fallerito
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_CHANNEL_ID=@Falles360
TELEGRAM_CHANNEL_URL=https://t.me/Falles360
TELEGRAM_CHANNEL_NAME=Falles360
TELEGRAM_WEBHOOK_SECRET=change-me-with-a-long-random-secret

# Cendra
CENDRA_SYNC_SOURCE_URL=https://www.cendradigital.com/category/actualidad/
CENDRA_SYNC_LIMIT=12
CENDRA_SYNC_TIMEOUT=15
